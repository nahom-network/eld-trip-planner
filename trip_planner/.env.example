# Geocoding (OpenCage — free tier: 2,500 req/day)
# Sign up at https://opencagedata.com/ to get your free API key
OPENCAGE_API_KEY=your_opencage_api_key_here

# PostgreSQL connection settings
DB_NAME=trip_planner
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# Django settings
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
USE_X_FORWARDED_HOST=True

# Static files backend
# False = local/WhiteNoise, True = Cloudflare R2 via django-storages
USE_CLOUDFLARE_R2=False

# STATIC_URL should match your custom static domain when using R2
# Example: https://static.yourdomain.com/
STATIC_URL=/static/

# Cloudflare R2 (only required when USE_CLOUDFLARE_R2=True)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_REGION=auto
# Optional override. If empty, endpoint is built from ACCOUNT_ID.
CLOUDFLARE_R2_ENDPOINT_URL=
# Optional: custom CDN/domain for objects (sets STATIC_URL and MEDIA_URL automatically)
CLOUDFLARE_R2_CUSTOM_DOMAIN=
# Optional: prefix/folder inside bucket for static files (default: static)
CLOUDFLARE_R2_STATIC_LOCATION=static
# Optional: prefix/folder inside bucket for media/uploads (ELD PDFs etc.) (default: media)
CLOUDFLARE_R2_MEDIA_LOCATION=media

# Gunicorn (Docker only)
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
